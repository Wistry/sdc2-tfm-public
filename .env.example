# Directorio base para datos SDC2 locales.
SDC2_DATA_ROOT=/ruta/a/datos/sdc2

# Cubos de desarrollo y validacion. Pueden sobrescribir SDC2_DATA_ROOT.
SDC2_10GB_CUBE=/ruta/a/datos/sdc2/sky_dev_v2.fits
SDC2_40GB_CUBE=/ruta/a/datos/sdc2/sky_ldev_v2.fits

# Truth catalogue correspondiente a la ejecucion que se vaya a realizar.
SDC2_TRUTH=/ruta/a/datos/sdc2/sky_ldev_truthcat_v2.txt

# Ejecutable SoFiA y raiz del repositorio del scorer oficial.
SOFIA_BIN=sofia
SCORER_ROOT=/ruta/al/repositorio/ska-sdc-2
